<div>
    {{#each products}}
    <div>
        <h2>{{this.title}}</h2>
        <p>{{this.description}}</p>
        <p>Precio: {{this.price}}</p>
        <p>Categoría: {{this.category}}</p>
        <button onclick="addToCart('{{this._id}}')">Agregar al carrito</button>
    </div>
    {{/each}}
</div>

<div>
    <button {{#unless prevLink}}disabled{{/unless}} onclick="location.href='{{prevLink}}'">Anterior</button>
    <button {{#unless nextLink}}disabled{{/unless}} onclick="location.href='{{nextLink}}'">Siguiente</button>
</div>
